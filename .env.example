# ──────────────────────────────────────────────────────
# Buñolnails — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://bunolnails.com

# Contact form — email recipient
CONTACT_EMAIL=info@bunolnails.com

# Resend API key — OBLIGATORIO para que el formulario de contacto funcione
# 1. Crear cuenta gratuita en https://resend.com (3.000 emails/mes gratis)
# 2. Settings → API Keys → Create API Key
# 3. Pegar la clave aquí
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rate limiting — opcional, recomendado en producción con alto tráfico
# Sustituye el rate limiting en memoria (no persiste entre instancias serverless)
# Crear cuenta gratuita en https://upstash.com → Redis → crear base de datos
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
