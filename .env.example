# ──────────────────────────────────────────────────────
# Buñolnails — Environment Variables Example
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://bunolnails.com

# Contact form — email recipient
# Used in /app/api/contact/route.ts
CONTACT_EMAIL=info@bunolnails.com

# Email provider (choose one and uncomment)
# Option 1: Resend (recommended for Next.js)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 3: SMTP (e.g. Gmail, Zoho)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# SMTP_FROM=noreply@bunolnails.com

# Rate limiting (optional — use Upstash Redis in production for multi-instance)
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
